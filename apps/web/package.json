{
  "name": "@octo/web",
  "version": "1.0.12",
  "private": true,
  "main": "out-election/main/index.js",
  "homepage": ".",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "dev-ele": "concurrently -k -n=web,ele -c=green,blue \"vite\" \"wait-on tcp:3000 && npm-run-all watch\"",
    "watch": "tsc-watch -p tsconfig.e.json --onSuccess \"npm-run-all start:electron\"",
    "start:electron": "cross-env NODE_ENV=development electron .",
    "build": "vite build",
    "build:analyzer": "cross-env ANALYZER=true vite build",
    "build-ele:mac": "npm-run-all compile:electron electron:build:mac",
    "build-ele:mac-x64": "npm-run-all clean:dist-ele compile:electron electron:build:mac-x64",
    "build-ele:mac-arm64": "npm-run-all clean:dist-ele compile:electron electron:build:mac-arm64",
    "build-ele:mac-both": "npm-run-all compile:electron electron:build:mac-both",
    "build-ele:mac-universal": "npm-run-all clean:dist-ele compile:electron electron:build:mac-universal",
    "build-ele:mac-universal-fallback": "npm-run-all clean:dist-ele compile:electron electron:build:mac-universal-fallback",
    "build-ele:mac-universal-simple": "npm-run-all clean:dist-ele compile:electron electron:build:mac-universal-simple",
    "build-ele:win": "npm-run-all compile:electron electron:build:win",
    "build-ele:linux": "npm-run-all compile:electron electron:build:linux",
    "build-ele:linux-arm64": "npm-run-all compile:electron electron:build:linux-arm64",
    "build-ele": "npm-run-all compile:electron electron:build:all",
    "clean:dist-ele": "rm -rf dist-ele",
    "compile:electron": "tsc -p tsconfig.e.json",
    "electron:build:mac": "electron-builder --mac -c",
    "electron:build:mac-x64": "electron-builder --mac --x64 -c electron-builder-x64.js",
    "electron:build:mac-arm64": "electron-builder --mac --arm64 -c electron-builder-arm64.js",
    "electron:build:mac-both": "electron-builder --mac --x64 --arm64 -c",
    "electron:build:mac-universal": "electron-builder --mac --x64 --arm64 -c electron-builder-universal.js",
    "electron:build:win": "electron-builder --win -c",
    "electron:build:linux": "electron-builder --linux --x64 -c",
    "electron:build:linux-arm64": "electron-builder --linux --arm64 -c",
    "electron:build:all": "electron-builder -mw -c",
    "test": "vitest run",
    "test:arch-builds": "./scripts/test-arch-builds.sh",
    "debug:build-structure": "./scripts/debug-build-structure.sh",
    "test:arch-specific": "./scripts/test-arch-specific-builds.sh",
    "verify:dmg": "./scripts/verify-dmg-architecture.sh",
    "test:universal": "./scripts/test-universal-build.sh",
    "eject": "react-app-rewired eject",
    "clean": "rimraf node_modules dist-ele build dist-ele .turbo",
    "tauri": "tauri",
    "storybook": "storybook dev -p 16006",
    "build-storybook": "storybook build",
    "test:storybook": "vitest run --config vitest.storybook.config.ts"
  },
  "dependencies": {
    "@octo/base": "workspace:*",
    "@octo/contacts": "workspace:*",
    "@octo/datasource": "workspace:*",
    "@octo/login": "workspace:*",
    "@douyinfe/semi-icons": "^2.93.0",
    "@douyinfe/semi-ui": "^2.93.0",
    "@tauri-apps/api": "^1.5.0",
    "classnames": "^2.3.1",
    "electron-log": "^5.1.2",
    "electron-screenshots": "^0.5.26",
    "electron-updater": "^6.1.8",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "tmp": "^0.2.2",
    "web-vitals": "^2.1.4",
    "wukongimjssdk": "^1.3.5"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-mcp": "^0.4.2",
    "@storybook/addon-onboarding": "^10.3.3",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@tauri-apps/cli": "^1.5.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.10.5",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^8.2.2",
    "electron": "26.0.0",
    "electron-builder": "^26.0.12",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-storybook": "^10.3.3",
    "npm-run-all": "^4.1.5",
    "postcss-import": "^16.1.1",
    "react-dom": "^18.3.1",
    "storybook": "^10.3.3",
    "tsc-watch": "^6.0.4",
    "typescript": "^5.3.3",
    "vite": "^8.0.3",
    "vite-plugin-commonjs": "^0.10.4",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
